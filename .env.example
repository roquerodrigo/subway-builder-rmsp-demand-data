# subway-builder-rmsp-demand-data — copie para .env e ajuste se necessário. Todos têm default.

# Onde ficam os dados baixados/processados (default: ./data/sources, dentro do projeto).
# DEMAND_SOURCES_DIR=./data/sources

# --- URLs das pesquisas (aquisição própria; comando `sources`) ---
# DEMAND_OD_ZIP_URL=https://transparencia.metrosp.com.br/sites/default/files/Site_190225_PesquisaOD2023.zip
# DEMAND_CNEFE_URL=https://ftp.ibge.gov.br/Cadastro_Nacional_de_Enderecos_para_Fins_Estatisticos/Censo_Demografico_2022/Arquivos_CNEFE/CSV/UF/35_SP.zip
# DEMAND_CENSO_URL=https://ftp.ibge.gov.br/Censos/Censo_Demografico_2022/Agregados_por_Setores_Censitarios/Agregados_por_Setor_csv/Agregados_por_setores_basico_BR_20260520.zip

# --- algoritmo ---
# pessoas por pop: N_zona = round(pop_zona / people_per_pop). Menor = mais pops.
# DEMAND_PEOPLE_PER_POP=300
# resolução base da grade de densidade (graus).
# DEMAND_DENSITY_CELL=0.0045   # ~500 m (menor = mais pontos)
# refino: a agregação roda em density_cell/subdiv e cada zona só fica mais fina que
# density_cell se a demanda por ponto passar do teto abaixo.
# DEMAND_DENSITY_SUBDIV=4   # ~125 m no limite
# teto de pessoas (moradores + trabalhadores) por ponto.
# DEMAND_MAX_PER_POINT=5000   # 0 = sem refino (grade fixa em density_cell)
# destinos de trabalho mantidos por zona de origem (cauda O-D é ruído).
# DEMAND_DEST_CAP=0   # 0 = sem limite (usa todos os destinos O-D)
# tamanho mínimo de pop (funde os minúsculos: limita nº de pops da zona a P/min_pop_size).
# DEMAND_MIN_POP_SIZE=50   # 0 = sem limite
# fração da demanda distribuída IGUAL entre células da zona (resto por peso). 0.5 = metade/metade.
# DEMAND_EQUAL_FRACTION=0.75
# semente da amostragem ponderada (reprodutível).
# DEMAND_SEED=42

# --- GeoSampa (lotes IPTU: densidade por área construída/uso, só na capital) ---
# ausente = tudo no CNEFE. `sources` baixa via WFS (~1,68M lotes, ~15min).
# DEMAND_LOTE_WFS_URL=http://wfs.geosampa.prefeitura.sp.gov.br/geoserver/geoportal/wfs
# DEMAND_LOTE_LAYER=geoportal:lote_cidadao
# DEMAND_LOTE_PAGE=10000
# só usa lotes se cobrirem >= esta fração das células CNEFE da zona (evita borda da capital).
# DEMAND_LOTE_MIN_COVERAGE=0.5

# --- saída ---
# DEMAND_OUT_DIR=./out
